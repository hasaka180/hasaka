# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Password that gates /studio and the write/upload APIs.
# If unset locally the gate is skipped. In production it is REQUIRED (studio is disabled without it).
STUDIO_PASSWORD=

# ── Appwrite (content + media storage) ──
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1   # use your project's regional endpoint, e.g. https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_COLLECTION_ID=
# Storage bucket id for image/video uploads (create a bucket with read access for "Any").
APPWRITE_BUCKET_ID=

# ── Crisp live chat (reply from the Crisp iOS app) ──
# Public — exposed to the browser. Get it from Crisp → Settings → Website Settings → Website ID.
NEXT_PUBLIC_CRISP_WEBSITE_ID=
