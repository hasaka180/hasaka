# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Password that gates /studio and the case write APIs (POST/PUT/DELETE).
# If unset locally, the gate is skipped. In production it is REQUIRED (studio is disabled without it).
STUDIO_PASSWORD=

# Vercel KV — auto-injected when you connect a KV store in the Vercel dashboard.
# Only needed if you want to test KV locally (otherwise the local JSON file is used).
KV_REST_API_URL=
KV_REST_API_TOKEN=
